{
  "manifest_version": 3,
  "name": "countDown",
  "short_name": "countDown",
  "description": "__MSG_manifest_descr__",
  "version": "4.2",
  "default_locale": "en",
  "offline_enabled": true,
  "icons": {
    "128": "img/icon-128.png",
    "48": "img/icon-48.png",
    "19": "img/icon.png"
  },
  "background": {
    "service_worker": "js/countdown.js"
  },
  "action": {
    "default_icon": "img/icon.png",
    "default_title": "countDown",
    "default_popup": "views/popup.html"
  },
  "permissions": [
    "notifications",
    "tts",
    "storage",
    "alarms",
    "offscreen"
  ],
  "commands": {
    "timer-start": {
      "suggested_key": {
        "default": "Ctrl+Insert",
        "mac": "Ctrl+Insert"
      },
      "description": "Start current timer"
    },
    "_execute_action": {
      "suggested_key": {
        "windows": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y",
        "chromeos": "Ctrl+Shift+U",
        "linux": "Ctrl+Shift+J"
      }
    }
  }
}